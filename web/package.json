{
  "name": "boxfleet-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:api": "cross-env BOXFLEET_DEV_API=1 vite --host 127.0.0.1",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "lint": "eslint .",
    "test": "vitest run src",
    "test:e2e": "playwright test",
    "test:e2e:all": "cross-env BOXFLEET_E2E_BROWSERS=chromium,firefox,webkit playwright test",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@cloudflare/kumo": "^2.5.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "date-fns": "^4.4.0",
    "diff": "^9.0.0",
    "meta-json-schema": "^1.19.28",
    "monaco-editor": "^0.56.0",
    "monaco-yaml": "^5.5.1",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.77.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/react": "^16.3.2",
    "@types/diff": "^7.0.2",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "dompurify": "3.4.12"
  }
}
